# EstateFlow server-side AI configuration.
# Copy to .env only on a private machine or hosting provider. Never commit real values.

# Required for API mode. Store the real value only as a server-side secret.
OPENAI_API_KEY=replace_with_your_server_side_key

# Optional alias for hosts that prefer this env name.
AI_API_KEY=replace_with_your_server_side_key

# The backend only allows this model for the MVP cost cap.
AI_MODEL=gpt-5.4-nano
AI_CLASSIFIER_MODEL=gpt-5.4-nano
AI_API_BASE_URL=https://api.openai.com/v1/chat/completions

# Comma-separated origins allowed to call /api/ask-ai.
AI_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://claudeuse8599.github.io

# Ask AI safety controls. Usage tracks actual server-side LLM processing time.
ASK_AI_USAGE_LIMIT_MS=300000
ASK_AI_MAX_MESSAGES_PER_MINUTE=10
ASK_AI_DUPLICATE_MESSAGE_WINDOW_MS=60000
ASK_AI_MAX_BLOCKED_ATTEMPTS_PER_MINUTE=8

# GitHub Pages should remain in demo mode because it cannot run server-side code.
ASK_AI_MODE=demo

# Convex backend setup. Public frontend uses the HTTP URL, not a secret key.
CONVEX_DEPLOYMENT=replace_with_convex_deployment_name
ESTATEFLOW_CONVEX_HTTP_URL=https://replace-with-your-deployment.convex.site
CONVEX_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://claudeuse8599.github.io

# Optional CI deploy key. Treat this as a secret and store it only in GitHub Actions secrets.
CONVEX_DEPLOY_KEY=replace_with_convex_deploy_key_if_using_ci
