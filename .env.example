# EstateFlow server-side AI configuration.
# Copy to .env only on a private machine or hosting provider. Never commit real values.

# Required for API mode. Store the real value only as a server-side secret.
AI_API_KEY=replace_with_your_server_side_key

# Optional OpenAI-compatible settings.
AI_MODEL=replace_with_model_name
AI_API_BASE_URL=https://api.openai.com/v1/chat/completions

# Comma-separated origins allowed to call /api/ask-ai.
AI_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://claudeuse8599.github.io

# GitHub Pages should remain in demo mode because it cannot run server-side code.
ASK_AI_MODE=demo
